# Salin file ini menjadi `.env` lalu sesuaikan nilainya.

# ── Database ───────────────────────────────────────────────
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/rcms

# ── JWT ────────────────────────────────────────────────────
# WAJIB diganti dengan string acak panjang di produksi.
# Contoh generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=ganti-dengan-secret-acak-yang-panjang
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Aplikasi ───────────────────────────────────────────────
# Origin frontend yang diizinkan (CORS), pisahkan dengan koma jika lebih dari satu.
CORS_ORIGINS=http://localhost:5173

# Folder penyimpanan file upload (relatif terhadap backend/)
UPLOAD_DIR=uploads
